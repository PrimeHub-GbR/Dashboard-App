# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Supabase Service Role Key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# n8n Integration
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_HMAC_SECRET=your-hmac-secret-here

# n8n REST API (für Workflow Monitor — PROJ-7)
N8N_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=your-n8n-api-key-here

# Vercel Cron Secret (protects /api/jobs/timeout endpoint)
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# PROJ-2: Google Drive Order Sync (Service Account — direkt, ohne n8n)
# Erstelle unter: https://console.cloud.google.com → IAM → Service Accounts
# Den Service Account muss Lesezugriff auf den Drive-Ordner haben (Freigabe per E-Mail)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Private Key aus der JSON-Datei des Service Accounts (alles in eine Zeile, \n für Zeilenumbrüche)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
